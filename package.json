{
  "name": "aipersona-demo",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "./scripts/dev-api.sh",
    "dev:worker": "./scripts/dev-worker.sh",
    "dev:up": "./scripts/docker-compose.sh up --build",
    "dev:up:detached": "./scripts/docker-compose.sh up --build -d",
    "dev:down": "./scripts/docker-compose.sh down",
    "dev:logs": "./scripts/docker-compose.sh logs -f --tail=200",
    "dev:ps": "./scripts/docker-compose.sh ps",
    "dev:temporal": "./scripts/docker-compose.sh --profile temporal up -d temporal",
    "stage:up": "ENV_FILE=.env.stage ENV_TEMPLATE_FILE=.env.stage.example COMPOSE_FILE=docker-compose.stage.yml ./scripts/docker-compose.sh up --build",
    "stage:up:detached": "ENV_FILE=.env.stage ENV_TEMPLATE_FILE=.env.stage.example COMPOSE_FILE=docker-compose.stage.yml ./scripts/docker-compose.sh up --build -d",
    "stage:down": "ENV_FILE=.env.stage ENV_TEMPLATE_FILE=.env.stage.example COMPOSE_FILE=docker-compose.stage.yml ./scripts/docker-compose.sh down",
    "stage:logs": "ENV_FILE=.env.stage ENV_TEMPLATE_FILE=.env.stage.example COMPOSE_FILE=docker-compose.stage.yml ./scripts/docker-compose.sh logs -f --tail=200",
    "stage:ps": "ENV_FILE=.env.stage ENV_TEMPLATE_FILE=.env.stage.example COMPOSE_FILE=docker-compose.stage.yml ./scripts/docker-compose.sh ps",
    "db:migrate": "./scripts/db-migrate.sh",
    "db:migrate:docker": "./scripts/docker-db-migrate.sh",
    "remote:bootstrap": "./scripts/remote-dev-bootstrap.sh",
    "remote:stop": "./scripts/remote-dev-stop.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test && pnpm run test:py",
    "test:web": "turbo run test",
    "test:py": "python3 -m compileall -q apps/api/src apps/worker/src apps/mcp/src && echo '✓ Python compile check passed'",
    "test:py:full": "cd apps/api && PYTHONPATH=src:../worker/src python3 -m pytest tests/ -x -q",
    "check:contracts": "pnpm exec tsc -p packages/contracts/tsconfig.json --noEmit && pnpm exec tsc -p packages/domain-models/tsconfig.json --noEmit",
    "check:runtime": "python3 -m compileall apps/api/src apps/worker/src"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
