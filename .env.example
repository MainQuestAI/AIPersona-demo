# AIpersona Demo local runtime template
#
# This template is for host-side local runs.
# If you use Docker Compose as the default dev environment,
# copy `.env.compose.example` to `.env.compose` instead.

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=aipersona_demo
POSTGRES_USER=aipersona
POSTGRES_PASSWORD=aipersona_dev
DATABASE_URL=postgresql://aipersona:aipersona_dev@127.0.0.1:5432/aipersona_demo

APP_NAME=aipersona-api
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_KEY_REQUIRED=false
ENABLE_DEV_AUTH=true
OAUTH_SERVER_URL=http://127.0.0.1:3200
OAUTH_CLIENT_ID=aipersona-local-dev
OAUTH_CLIENT_SECRET=aipersona-local-dev-secret
SESSION_COOKIE_SECRET=replace-with-local-cookie-secret
WEB_APP_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
SHARED_DEMO_TEAM_SLUG=shared-demo
SHARED_DEMO_TEAM_NAME=共享演示团队

WORKER_APP_NAME=aipersona-worker

VITE_STUDY_RUNTIME_API_URL=http://127.0.0.1:8000
VITE_OAUTH_PORTAL_URL=http://localhost:5173
VITE_OAUTH_CLIENT_ID=aipersona-local-dev
VITE_ENABLE_DEV_AUTH=true

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_INPUT_COST_PER_1K=0
DASHSCOPE_OUTPUT_COST_PER_1K=0

OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
