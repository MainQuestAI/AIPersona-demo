# AIpersona Demo project environment template
#
# Do NOT commit real secrets.
# Prefer loading these from your unified secret store, direnv, or 1Password.

############################
# Remote Development
############################

DEV_SERVER_IP=100.75.231.2
DEV_SERVER_SSH_USER=dingcheng
DEV_SERVER_SSH_KEY_PATH=/Users/dingcheng/.ssh/id_ed25519_deploy

# Local forwarded ports for SSH tunnels
REMOTE_DB_LOCAL_PORT=15432
REMOTE_DOCKER_LOCAL_PORT=12375
REMOTE_TEMPORAL_LOCAL_PORT=7233
REMOTE_TEMPORAL_UI_LOCAL_PORT=8233

############################
# PostgreSQL
############################

# Recommended pattern:
# 1. Use SSH tunnel to map remote 5432 -> local 15432
# 2. Keep the application reading localhost
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=15432
POSTGRES_DB=aipersona_demo
POSTGRES_USER=
POSTGRES_PASSWORD=

# App-facing DSN used by API / repositories / future migrations
DATABASE_URL=postgresql://<user>:<password>@127.0.0.1:15432/aipersona_demo

############################
# Docker Remote API
############################

# Recommended pattern:
# 1. Use SSH tunnel to map remote 2375 -> local 12375
# 2. Point tools to the local forwarded endpoint
DOCKER_HOST=tcp://127.0.0.1:12375
REMOTE_DOCKER_API=http://127.0.0.1:12375
REMOTE_TEMPORAL_CONTAINER_NAME=aipersona-temporal-dev
REMOTE_TEMPORAL_IMAGE=temporalio/temporal:latest

############################
# API Runtime
############################

APP_NAME=aipersona-api
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

############################
# Worker / Temporal
############################

WORKER_APP_NAME=aipersona-worker
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_UI_URL=http://127.0.0.1:8233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=study-task-queue

############################
# LLM Cost Estimation
############################

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# Optional: if you want runtime artifacts to show cost estimate instead of token-only usage,
# fill the current pricing rules here.
DASHSCOPE_INPUT_COST_PER_1K=0
DASHSCOPE_OUTPUT_COST_PER_1K=0

############################
# Future Object Storage
############################

# Not used by R01/R02 yet.
# Keep placeholders here so later runtime batches stay consistent.
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
